#!/usr/bin/env bash

# ==============================================================================
# RENAISSANCE - USER LOGIN TEST
# ==============================================================================
# API Endpoint: POST /api/v1/user/auth/login
# Description: Logs in a user, returning a session token.
# Expected Output: A JSON response with success: true and the session token.
# Note: Replace <EMAIL> with the email address used during registration.
# ==============================================================================

curl -X POST http://127.0.0.1:8080/api/v1/user/auth/login \
  -H "Content-Type: application/json" \
  -d '{
    "email": "<EMAIL>",
    "password": "supersecurepassword123"
  }'
echo -e "\n"
